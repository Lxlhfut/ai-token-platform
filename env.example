# 复制本文件为 .env 并填写实际值

SECRET_KEY=change-me-to-a-random-64-char-string-in-production
DATABASE_URL=sqlite+aiosqlite:///./data/platform.db
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin123456!
PLATFORM_NAME=AI Token 中转站
CURRENCY=CNY
UPSTREAM_TIMEOUT=120
ALLOW_REGISTRATION=true
RECHARGE_NOTICE=使用兑换码（卡密）即可自助充值，在下方「充值余额」框中输入兑换码，充值后余额立即到账，即可按量调用 AI 模型。

# 支付宝支付配置（可选）
ALIPAY_APP_ID=
ALIPAY_APP_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=
ALIPAY_RETURN_URL=

# 微信支付 V3 Native 支付配置（可选）
# 商户号，微信商户平台 → 账户中心 → 商户信息
WECHAT_MCH_ID=
# 公众号/小程序 AppID，微信公众平台 → 开发 → 基本配置
WECHAT_APP_ID=
# API v3 密钥（32位），微信商户平台 → API安全 → APIv3密钥
WECHAT_API_V3_KEY=
# 商户 API 证书序列号（40位大写），微信商户平台 → API安全 → API证书
WECHAT_SERIAL_NO=
# 商户 API 私钥 PEM 内容（含头尾标识），需用双引号包裹多行字符串，换行用 \n 替代
WECHAT_PRIVATE_KEY=
# 支付结果回调通知地址（必须是公网 HTTPS），示例：https://ylxunlapi.top/api/payment/wechat/notify
WECHAT_NOTIFY_URL=